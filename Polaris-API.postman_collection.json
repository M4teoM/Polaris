{
  "info": {
    "name": "Polaris Hotel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('token_admin', json.token);",
                  "    console.log('Token admin guardado');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@polaris.com\",\n  \"contrasena\": \"admin123\"\n}"
            },
            "url": { "raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Operario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('token_operario', json.token);",
                  "    console.log('Token operario guardado');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"operario@polaris.com\",\n  \"contrasena\": \"operario123\"\n}"
            },
            "url": { "raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('token_cliente', json.token);",
                  "    console.log('Token cliente guardado');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"samutovar10@gmail.com\",\n  \"contrasena\": \"8888\"\n}"
            },
            "url": { "raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Credenciales Incorrectas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@polaris.com\",\n  \"contrasena\": \"contrasena_mal\"\n}"
            },
            "url": { "raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Ver mi usuario (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": { "raw": "http://localhost:8080/api/auth/me", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "me"] }
          }
        },
        {
